# Copy to .streamlit/secrets.toml and fill in to enable Mode A (prebuilt corpus).
# Leave unset to run in stateless Mode B only.

# Where the artifact bundle lives: "local" | "hf" | "url"
ARTIFACT_SOURCE = "hf"

# For ARTIFACT_SOURCE = "hf": a Hugging Face *dataset* repo holding ./artifacts
HF_ARTIFACT_REPO = "your-username/mirror-of-maya-index"

# For ARTIFACT_SOURCE = "url": a public https link to a .zip of the bundle
# ARTIFACT_URL = "https://example.com/mirror-of-maya-artifacts.zip"

# Must match the model the bundle was built with.
MODEL_ID = "facebook/dinov2-small"
POOLING = "cls"
